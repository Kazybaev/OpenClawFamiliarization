# Copy to .env and fill locally. Do not commit real secrets.

# Gemini accepts either GEMINI_API_KEY or GOOGLE_API_KEY.
GEMINI_API_KEY=replace_with_your_gemini_api_key
# GOOGLE_API_KEY=

# Telegram token from @BotFather.
TELEGRAM_BOT_TOKEN=replace_with_your_telegram_bot_token

# Optional gateway token. Generate a strong random value for remote access.
OPENCLAW_GATEWAY_TOKEN=replace_with_a_random_64_character_hex_token

# Default Gemini model for OpenClaw.
OPENCLAW_DEFAULT_MODEL=google/gemini-2.5-flash
